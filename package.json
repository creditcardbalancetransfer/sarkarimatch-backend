{
  "name": "sarkarimatch-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "SarkariMatch Backend - Cloudflare Workers API for government job listings with D1 database",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 3000",
    "dev:sandbox": "wrangler dev --ip 0.0.0.0 --port 3000",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create sarkarimatch-db",
    "db:schema": "wrangler d1 execute sarkarimatch-db --file=./schema.sql --remote",
    "db:schema:local": "wrangler d1 execute sarkarimatch-db --file=./schema.sql --local",
    "db:seed:local": "wrangler d1 execute sarkarimatch-db --local --command=\"INSERT INTO jobs (title, slug, department, sector, total_vacancies, status) VALUES ('Test Job', 'test-job', 'Test Dept', 'test', 10, 'active')\"",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.4.0"
  },
  "keywords": ["cloudflare", "workers", "hono", "d1", "sarkari", "government-jobs"],
  "author": "",
  "license": "ISC"
}
